# ShopCopilot AI Service Environment Configuration

# ========== 基础配置 ==========
ENVIRONMENT=development
DEBUG=true
PORT=8000

# ========== CORS 配置 ==========
# JSON 数组格式
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8081"]

# ========== LLM 配置（MiMo Token Plan）==========
LLM_API_KEY=tp-your-mimo-api-key
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_MODEL=mimo-v2.5
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=10000

# ========== MiMo 模型配置 ==========
MIMO_VISION_MODEL=mimo-v2.5
MIMO_PRO_MODEL=mimo-v2.5-pro

# ========== Embedding 配置（阿里百炼 text-embedding-v4）==========
# 阿里百炼 API Key，从 https://bailian.console.aliyun.com/ 获取
EMBEDDING_API_KEY=sk-your-dashscope-api-key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
# text-embedding-v4 支持维度：2048/1536/1024（默认）/768/512/256/128/64
EMBEDDING_DIMENSIONS=1024
EMBEDDING_USE_CUSTOM_DIMENSIONS=true
EMBEDDING_CHECK_CTX_LENGTH=false

# ========== 向量库配置 ==========
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=shop_knowledge

# ========== MySQL 配置（复用现有系统）==========
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=shop_operate_system

# ========== Redis 配置（复用现有系统）==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ========== LangFuse 可观测性配置 ==========
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ========== NL2SQL 配置 ==========
NL2SQL_MAX_ROWS=100
NL2SQL_TIMEOUT=30
NL2SQL_DANGLED_KEYWORDS=["DROP","DELETE","TRUNCATE","ALTER","UPDATE","INSERT"]

# ========== RAG 配置 ==========
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.6
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50

# ========== Agent 配置 ==========
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT=60

# ========== 长时记忆配置 ==========
MEMORY_ENABLED=true
MEMORY_TYPE=vector
MEMORY_TTL=2592000
MEMORY_TOP_K=5
MEMORY_COLLECTION_NAME=agent_memory

# ========== 多 Agent 协作配置 ==========
MULTI_AGENT_ENABLED=true
SUPERVISOR_MODEL=flash
VISION_AGENT_ENABLED=true

# ========== 后台管理系统配置 ==========
BACKEND_URL=http://localhost:8081
TOKEN_CACHE_TTL=300

# ========== 互联网搜索配置 ==========
SEARCH_API=tavily
TAVILY_API_KEY=your-tavily-api-key